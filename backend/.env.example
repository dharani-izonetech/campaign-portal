# ─── Option A: Full database URL ──────────────────────────────────────────────
# Takes precedence if set. Comment out if using Option B.
# DATABASE_URL=postgresql://postgres:password@localhost:5432/campaign_db

# ─── Option B: Individual connection parts (for VPS / remote DB) ──────────────
DB_HOST=your-vps-ip-or-hostname
DB_PORT=5432
DB_NAME=campaign_db
DB_USER=postgres
DB_PASSWORD=your-secure-password

# ─── PostgreSQL Schema ────────────────────────────────────────────────────────
# All tables will be created inside this schema
DB_SCHEMA=campaign_tweet

# ─── JWT ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
